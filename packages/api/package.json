{
  "name": "@eheikes/oscar-api",
  "version": "0.1.0",
  "description": "OSCAR assistant API",
  "type": "module",
  "files": [
    "bin/*",
    "dist/*",
    ".env.example",
    "LICENSE.txt",
    "rds-ca-bundle.pem"
  ],
  "main": "dist/index.js",
  "scripts": {
    "prepare": "husky",
    "prebuild": "del dist",
    "build": "ncc build src/serverless.ts -o dist --source-map",
    "prebuild:release": "del dist",
    "build:release": "ncc build src/serverless.ts -o dist --source-map --minify",
    "lint": "ts-standard --fix --verbose",
    "lint-hook": "ts-standard --verbose",
    "report-coverage": "codecov",
    "release": "bin/release.sh",
    "test": "run-s test:e2e",
    "test:e2e": "NODE_ENV=test NODE_OPTIONS='--import tsx' vitest run test/e2e",
    "start": "tsx ./src/server.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eheikes/oscar.git"
  },
  "keywords": [
    "api",
    "assistant",
    "productivity"
  ],
  "author": "Eric Heikes <eheikes@gmail.com>",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/eheikes/oscar/issues"
  },
  "homepage": "https://github.com/eheikes/oscar/tree/master/packages/api#readme",
  "devDependencies": {
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.12",
    "@types/supertest": "^6.0.2",
    "@vercel/ncc": "^0.38.1",
    "c8": "^9.1.0",
    "del-cli": "^5.1.0",
    "esmock": "^2.6.5",
    "husky": "^9.0.11",
    "npm-run-all": "^4.1.5",
    "supertest": "^7.1.4",
    "ts-standard": "^12.0.2",
    "tsx": "^4.22.1",
    "typescript": "^5.4.5",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "body-parser": "^2.2.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^5.2.0",
    "express-openid-connect": "^2.20.2",
    "knex": "^3.1.0",
    "pg": "^8.11.5",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "serverless-http": "^3.2.0",
    "uuid": "^14.0.0",
    "znv": "^0.4.0",
    "zod": "^3.23.8",
    "zod-validation-error": "^3.3.0"
  },
  "standard": {
    "env": {
      "node": true
    }
  },
  "nyc": {
    "check-coverage": true,
    "per-file": false,
    "lines": 95,
    "statements": 95,
    "functions": 95,
    "branches": 95,
    "include": [
      "src/**/*.ts"
    ],
    "reporter": [
      "lcov",
      "text-summary"
    ],
    "cache": false,
    "all": false,
    "report-dir": "./coverage"
  }
}
